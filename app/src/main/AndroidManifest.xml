<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".CurrenciesApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="UnusedAttribute">
        <!-- MainActivity is not exported. The launcher entry is the alias
             below, whose sole job is to satisfy the LAUNCHER intent-filter
             (which requires exported=true so the system launcher, running in
             a different UID, can fire the tap intent). The alias adds no new
             callable state — it just routes to MainActivity with the splash
             launch theme so the pre-onCreate window is a brand-colored splash
             instead of a theme-dependent background flash. -->
        <activity
            android:name=".view.main.MainActivity"
            android:exported="false" />
        <!-- nosemgrep: java.android.security.exported_activity.exported_activity -->
        <activity-alias
            android:name=".view.main.MainActivityLauncher"
            android:exported="true"
            android:targetActivity=".view.main.MainActivity"
            android:theme="@style/Theme.App.Starting"
            tools:ignore="ExportedActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity android:name=".view.preference.PreferenceActivity" />
        <activity android:name=".view.timeline.TimelineActivity" />

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>
