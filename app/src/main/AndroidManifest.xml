<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".CurrenciesApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="UnusedAttribute">
        <!-- Two launcher entries with different launch themes. Exactly one is
             enabled at a time (see PackageManager toggle in PreferenceViewModel).
             The non-OLED alias is enabled by default; picking an OLED theme
             option flips to the pure-black alias so the pre-onCreate window
             renders true black instead of blackOlive on cold start. -->
        <activity
            android:name=".view.main.MainActivity"
            android:exported="false" />
        <activity-alias
            android:name=".view.main.MainActivityLauncher"
            android:enabled="true"
            android:exported="true"
            android:targetActivity=".view.main.MainActivity"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".view.main.MainActivityLauncherPureBlack"
            android:enabled="false"
            android:exported="true"
            android:targetActivity=".view.main.MainActivity"
            android:theme="@style/AppTheme.PureBlack">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity android:name=".view.preference.PreferenceActivity" />
        <activity android:name=".view.timeline.TimelineActivity" />

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>
