<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cart_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/cart_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/snackbar_top_position"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cart_items"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/margin1x"
            android:paddingVertical="@dimen/margin1x" />

        <TextView
            android:id="@+id/cart_empty_hint"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/margin3x"
            android:gravity="center"
            android:text="@string/cart_empty_hint"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cart_add_item"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin2x"
            android:layout_marginTop="@dimen/margin1x"
            android:text="@string/cart_add_item"
            app:icon="@android:drawable/ic_input_add" />

        <!-- Totals card — mirrors main_display's rounded bg_display treatment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin2x"
            android:background="@drawable/bg_display"
            android:orientation="vertical"
            android:padding="@dimen/margin2x">

            <!-- header: FROM  ⇄  TO — same SearchableSpinner as the main screen.
                 Swap and fee-side are stacked in the middle column so the
                 fee arrow doesn't steal horizontal room from spinner_to when
                 it becomes visible. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <de.salomax.currencies.view.main.spinner.SearchableSpinner
                    android:id="@+id/cart_spinner_from"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/cart_swap"
                        style="@style/Widget.Material3.FloatingActionButton.Small.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="?attr/colorPrimary"
                        android:contentDescription="@string/desc_toggle_currencies"
                        android:src="@drawable/ic_swap_horiz"
                        app:tint="?attr/colorOnPrimary" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/cart_btn_fee_side"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin1x"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/fee_side_label"
                        android:padding="@dimen/margin1x"
                        android:src="@drawable/ic_fee_side_original_horizontal"
                        android:visibility="gone"
                        app:tint="?attr/colorError" />
                </LinearLayout>

                <de.salomax.currencies.view.main.spinner.SearchableSpinner
                    android:id="@+id/cart_spinner_to"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin2x"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cart_subtotal_label" />

                <TextView
                    android:id="@+id/cart_subtotal_value"
                    style="@style/TextAppearance.Material3.TitleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textDirection="ltr" />
            </LinearLayout>

            <TextView
                android:id="@+id/cart_fee_line"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/margin1x"
                android:textColor="?attr/colorError"
                android:textDirection="ltr"
                android:visibility="gone" />

            <!-- "True cost" in the base currency: shown only for fee-side ORIGINAL. -->
            <LinearLayout
                android:id="@+id/cart_subtotal_extra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/cart_subtotal_extra_label"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorError"
                    tools:text="True cost" />

                <TextView
                    android:id="@+id/cart_subtotal_extra_value"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorError"
                    android:textDirection="ltr"
                    tools:text="150.00 USD" />
            </LinearLayout>

            <!-- "Original value" in the destination currency: shown only for fee-side CONVERTED. -->
            <LinearLayout
                android:id="@+id/cart_total_extra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/cart_total_extra_label"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorError"
                    tools:text="Original value" />

                <TextView
                    android:id="@+id/cart_total_extra_value"
                    style="@style/TextAppearance.Material3.LabelSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorError"
                    android:textDirection="ltr"
                    tools:text="100.00 EUR" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin1x"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cart_total_label" />

                <TextView
                    android:id="@+id/cart_total_value"
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textDirection="ltr" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Slide-up calculator keypad. Behaves like a soft IME: shown when a
         value field is tapped, hidden on back-press or outside touch. -->
    <FrameLayout
        android:id="@+id/cart_keypad_container"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:background="?android:attr/colorBackground"
        android:elevation="8dp"
        android:visibility="gone">

        <include
            android:id="@+id/cart_keypad_regular"
            layout="@layout/main_keypad"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/cart_keypad_extended"
            layout="@layout/main_keypad_extended"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>
</FrameLayout>
