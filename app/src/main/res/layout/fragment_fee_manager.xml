<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/margin3x"
        android:paddingVertical="@dimen/margin2x">

        <!-- fee side -->
        <TextView
            android:id="@+id/labelFeeSide"
            style="@style/TextAppearance.Material3.LabelLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/margin1x"
            android:text="@string/fee_side_label" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleFeeSide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin2x"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSideOriginal"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fee_side_original" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSideConverted"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fee_side_converted" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- global exchange -->
        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/margin2x"
            android:paddingBottom="@dimen/margin1x"
            android:text="@string/fee_section_global_exchange" />

        <LinearLayout
            android:id="@+id/listGlobalExchange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddGlobalExchange"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin1x"
            android:text="@string/fee_add" />

        <!-- global bank -->
        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/margin3x"
            android:paddingBottom="@dimen/margin1x"
            android:text="@string/fee_section_global_bank" />

        <LinearLayout
            android:id="@+id/listGlobalBank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddGlobalBank"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin1x"
            android:text="@string/fee_add" />

        <!-- specific pair -->
        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/margin3x"
            android:paddingBottom="@dimen/margin1x"
            android:text="@string/fee_section_specific_pair" />

        <LinearLayout
            android:id="@+id/listSpecificPair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSpecificPair"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin1x"
            android:text="@string/fee_add" />

    </LinearLayout>
</ScrollView>
