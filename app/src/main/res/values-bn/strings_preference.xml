    <string name="category_about">এই অ্যাপ সম্পর্কে</string>
    <string name="disclaimer_title">বিশেষ বিজ্ঞপ্তি</string>
    <string name="disclaimer_summary">যদিও অ্যাপটি ভালোভাবে লিখা ও পরীক্ষা করা, <b>এর কোন নিশ্চয়তা নেই যে উপাত্ত এখানে দেখানো হয়েছে তা সঠিক</b>। এই বিনিময় হার তৃতীয় পক্ষদ্বারা উৎপাদিত এবং এই অ্যাপ নিশ্চিত করতে পারবে না যে সেগুলো সত্য বা হালনাগাদকৃত \nযোগ করা যায় যে, বিনিময় হারগুলো – সঠিক হলেও – তোমার ব্যাংকের ব্যবহৃত হার থেকে আলাদা হতে পারে।\nসবশেষে: ভুল হয়। অন্ধভাবে কাউকে বিশ্বাস করবে না! এটা বলার পরেও, নিশ্চিত থাকো এই অ্যাপটি ঠিকভাবে কাজ করা নিয়ে কোন দ্বিধা থাকলে এই অ্যাপ আমি প্রকাশ করতাম না।</string>
    <string name="sourcecode_title">কোড উৎস</string>
    <string name="sourcecode_summary">এই অ্যাপটি মুক্ত উৎস। কোড ভাণ্ডারে গিয়ে কোন সমস্যা জানাতে পারো, কিভাবে অবদান রাখতে হয় জানতে পারো বা শুধু উৎস দেখতে পারো।</string>
