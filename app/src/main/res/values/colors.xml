<?xml version="1.0" encoding="utf-8"?>
<resources>
   <!-- https://www.schemecolor.com/dollar-bill-color-scheme.php -->
   <color name="dirtyWhite">#FAF7F2</color>
   <color name="blackOlive">#333331</color>
   <color name="dollarBill">#85BB65</color>
   <color name="seaGreen">#228d57</color>

   <color name="color_primary">@color/dollarBill</color>
   <color name="color_keypad_operators">@color/color_primary</color>
   <color name="color_keypad_delete">?attr/colorError</color>

   <!-- light -->
   <color name="displayOverlay">#26808080</color>
   <color name="colorBackground">@color/dirtyWhite</color>
   <!-- pure black (equals light in light mode) -->
   <color name="displayOverlayPureBlack">@color/displayOverlay</color>
   <color name="colorBackgroundPureBlack">@color/colorBackground</color>

   <!-- Launch/splash background — transparent so no colored frame is drawn
        before the activity paints its first frame, regardless of theme. -->
   <color name="windowBackground">@android:color/transparent</color>
</resources>
